# App
APP_URL=http://localhost:5173
DATABASE_URL=postgresql://user:password@localhost:5432/my_pim_oms
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
REDIS_URL=redis://localhost:6379

# GitHub OAuth (github.com/settings/developers > OAuth Apps > New OAuth App)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Exact Online (developer.exactonline.com > App Center)
EXACT_DIVISION=your-division-id
EXACT_CLIENT_ID=your-exact-client-id
EXACT_CLIENT_SECRET=your-exact-client-secret
EXACT_REDIRECT_URI=http://localhost:3000/api/exact-online/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXACT_TOKEN_SECRET=

# Mail (Mailtrap sandbox — get credentials from mailtrap.io > Inboxes > SMTP Settings)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_SECURE=false
MAIL_USER=your-mailtrap-username
MAIL_PASS=your-mailtrap-password
MAIL_FROM="PIM OMS" <noreply@pim-oms.com>
